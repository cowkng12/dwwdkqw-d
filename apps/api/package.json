{
  "name": "@mrkt/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "node --check src/server.js",
    "start": "node src/server.js",
    "telegram:session": "node scripts/generate-session.js",
    "telegram:check": "node scripts/check-account.js",
    "bot:setup": "node scripts/setup-bot.js",
    "mrkt:token": "node scripts/get-mrkt-token.js",
    "mrkt:debug": "node scripts/debug-mrkt-items.js",
    "mrkt:debug:raw": "node scripts/debug-mrkt-raw.js",
    "mrkt:debug:summary": "node scripts/debug-mrkt-summary.js",
    "mrkt:debug:shape": "node scripts/debug-mrkt-shape.js",
    "bot:chats": "node scripts/get-bot-chats.js",
    "alerts:run": "node scripts/run-alert-scan.js",
    "alerts:poll": "node scripts/poll-alerts.js",
    "alerts:poll:4ton": "powershell -ExecutionPolicy Bypass -File ./scripts/start-4ton-monochrome.ps1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "input": "^1.0.1",
    "sharp": "^0.34.5",
    "telegram": "^2.26.22"
  }
}
